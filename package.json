{
	"name": "promap",
	"version": "0.1.0",
	"description": "Projection mapping tool",
	"main": "./out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"preview": "electron-vite preview",
		"build:win": "electron-vite build && electron-builder --win --dir",
		"dist:win": "electron-vite build && electron-builder --win"
	},
	"build": {
		"appId": "com.promap.app",
		"productName": "ProMap",
		"directories": {
			"output": "release"
		},
		"files": [
			"out/**/*"
		],
		"win": {
			"target": [
				{
					"target": "portable",
					"arch": ["x64"]
				}
			],
			"icon": null
		},
		"portable": {
			"artifactName": "ProMap-${version}-portable.exe"
		}
	},
	"dependencies": {
		"pixi.js": "^8.17.1"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.1",
		"electron": "^41.0.2",
		"electron-builder": "^26.8.1",
		"electron-vite": "^5.0.0",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.0"
	}
}
